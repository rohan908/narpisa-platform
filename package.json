{
  "name": "narpisa-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @narpisa/web dev",
    "dev:backend": "pnpm --filter @narpisa/pdf-worker dev",
    "dev:backend-worker": "pnpm --filter @narpisa/pdf-worker dev:worker",
    "format:backend": "pnpm --filter @narpisa/pdf-worker format",
    "check:backend": "pnpm --filter @narpisa/pdf-worker lint && pnpm --filter @narpisa/pdf-worker typecheck && pnpm --filter @narpisa/pdf-worker test",
    "lint": "turbo run lint",
    "typecheck:ts": "pnpm --filter @narpisa/web typecheck",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @narpisa/web test:e2e",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotted-map": "^3.1.0"
  }
}
