# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend runtime
PDF_WORKER_PORT=8000
PDF_WORKER_LOG_LEVEL=INFO
PDF_WORKER_FETCH_TIMEOUT_SECONDS=20
PDF_WORKER_FETCH_MAX_BYTES=10485760
PDF_WORKER_FETCH_ALLOWED_DOMAINS=documents.example.org,data.example.org
PDF_WORKER_TASKS_PROVIDER=inline
PDF_WORKER_TASK_AUTH_ENABLED=false

# Supabase service access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=public

# GCP / Cloud Tasks
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
CLOUD_TASKS_QUEUE=narpisa-pdf-jobs
CLOUD_RUN_SERVICE_URL=https://your-cloud-run-service-url.a.run.app
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=cloud-tasks-invoker@your-gcp-project-id.iam.gserviceaccount.com
CLOUD_TASKS_AUDIENCE=https://your-cloud-run-service-url.a.run.app
