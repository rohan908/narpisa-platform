# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PDF_WORKER_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Comma-separated Toolpad OAuth ids mapped to Supabase (e.g. google,microsoft-entra-id)
# NEXT_PUBLIC_AUTH_OAUTH_PROVIDERS=

# Backend
PDF_WORKER_PORT=8000
PDF_WORKER_LOG_LEVEL=INFO
PDF_WORKER_FETCH_TIMEOUT_SECONDS=20
PDF_WORKER_FETCH_MAX_BYTES=10485760
PDF_WORKER_FETCH_CHUNK_SIZE_BYTES=1048576
PDF_WORKER_DOWNLOAD_DIR=/tmp/narpisa-pdf-worker
KEEP_DOWNLOADED_PDFS=false
CELERY_BROKER_URL=redis://localhost:6379/0

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_SCHEMA=public
