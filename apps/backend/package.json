{
  "name": "@narpisa/pdf-worker",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "lint": "python -m ruff check app tests && python -m black --check app tests",
    "typecheck": "python -m mypy app",
    "test": "python -m pytest -q",
    "build": "python -m compileall app"
  }
}
